# Firebase Configuration — replace with your Firebase project values
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000:web:000000

# Set to "true" to use Firebase emulators in dev
VITE_USE_EMULATORS=false

# Optional same-origin exercise catalog proxy. Leave default for Firebase Hosting rewrite.
VITE_EXERCISE_API_BASE_URL=/api/exercises

# Local dev proxy target for Vite -> local exercise proxy
VITE_EXERCISE_PROXY_TARGET=http://127.0.0.1:8787

# Keep false to use Kabunga's free local muscle-focus visuals instead of the paid image API
VITE_ENABLE_REMOTE_MUSCLE_IMAGE_PROVIDER=false
