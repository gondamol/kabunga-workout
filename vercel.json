{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/exercises",
      "destination": "/api/exercises/[...route]"
    },
    {
      "source": "/api/exercises/:path*",
      "destination": "/api/exercises/[...route]"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
