rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isLinkedCoach(athleteId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/coachAthletes/$(athleteId))
        && get(/databases/$(database)/documents/coachAthletes/$(athleteId)).data.coachId == request.auth.uid;
    }

    function canAccessCommunityGroup(groupId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/communityGroups/$(groupId))
        && (
          get(/databases/$(database)/documents/communityGroups/$(groupId)).data.isPublic == true
          || request.auth.uid in get(/databases/$(database)/documents/communityGroups/$(groupId)).data.memberIds
        );
    }

    function isCommunityMetadataUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.name == resource.data.name
        && request.resource.data.description == resource.data.description
        && request.resource.data.kind == resource.data.kind
        && request.resource.data.isPublic == resource.data.isPublic
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function isSelfJoiningPublicCommunity() {
      return resource.data.isPublic == true
        && !(request.auth.uid in resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.memberIds.hasAll(resource.data.memberIds);
    }

    function isSelfLeavingCommunity() {
      return request.auth.uid in resource.data.memberIds
        && !(request.auth.uid in request.resource.data.memberIds)
        && resource.data.memberIds.size() == request.resource.data.memberIds.size() + 1
        && resource.data.memberIds.hasAll(request.resource.data.memberIds);
    }

    function isSelfJoiningWithInviteCode(groupId) {
      return !(request.auth.uid in resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.resource.data.inviteCode is string
        && exists(/databases/$(database)/documents/communityInvites/$(request.resource.data.inviteCode))
        && get(/databases/$(database)/documents/communityInvites/$(request.resource.data.inviteCode)).data.groupId == groupId
        && get(/databases/$(database)/documents/communityInvites/$(request.resource.data.inviteCode)).data.status == 'active';
    }

    // ─── Users ───
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Users cannot delete their profile
    }

    // ─── Workouts ───
    match /workouts/{workoutId} {
      allow read: if isOwner(resource.data.userId) || isLinkedCoach(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ─── Challenges ───
    match /challenges/{challengeId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ─── Meals ───
    match /meals/{mealId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ─── Coach codes ───
    match /coachCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.coachId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.coachId == request.auth.uid;
    }

    // ─── Coach-athlete links ───
    // Doc ID is athleteId.
    match /coachAthletes/{athleteId} {
      allow read: if isOwner(athleteId) || (isSignedIn() && resource.data.coachId == request.auth.uid);
      allow create: if isOwner(athleteId) && request.resource.data.athleteId == request.auth.uid;
      allow update: if isOwner(athleteId) || (isSignedIn() && resource.data.coachId == request.auth.uid);
      allow delete: if isOwner(athleteId) || (isSignedIn() && resource.data.coachId == request.auth.uid);
    }

    // ─── Coach assigned plans ───
    match /coachPlans/{planId} {
      allow read: if isSignedIn()
        && (resource.data.coachId == request.auth.uid || resource.data.athleteId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.coachId == request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.coachId == request.auth.uid || resource.data.athleteId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.coachId == request.auth.uid;
    }

    // ─── Community groups ───
    match /communityGroups/{groupId} {
      allow read: if isSignedIn()
        && (resource.data.isPublic == true || request.auth.uid in resource.data.memberIds);
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if isSignedIn()
        && (
          resource.data.ownerId == request.auth.uid
          || (
            isCommunityMetadataUnchanged()
            && (
              isSelfJoiningPublicCommunity()
              || isSelfLeavingCommunity()
              || isSelfJoiningWithInviteCode(groupId)
            )
          )
        );
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ─── Community invite codes ───
    match /communityInvites/{inviteCode} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'active'
        && exists(/databases/$(database)/documents/communityGroups/$(request.resource.data.groupId))
        && get(/databases/$(database)/documents/communityGroups/$(request.resource.data.groupId)).data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ─── Community messages ───
    match /communityMessages/{messageId} {
      allow read: if canAccessCommunityGroup(resource.data.groupId);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && exists(/databases/$(database)/documents/communityGroups/$(request.resource.data.groupId))
        && request.auth.uid in get(/databases/$(database)/documents/communityGroups/$(request.resource.data.groupId)).data.memberIds;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── Iron Protocol 1RMs ───
    match /oneRepMaxes/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ─── Fitness Dailies ───
    match /fitnessDailies/{userId}/logs/{date} {
      allow read, write: if isOwner(userId);
    }

    // ─── Athlete Health Flags ───
    match /athleteHealthFlags/{athleteId}/checks/{date} {
      allow read, write: if isOwner(athleteId);
    }

    match /athleteHealthFlags/{athleteId}/summaries/{date} {
      allow read: if isOwner(athleteId) || isLinkedCoach(athleteId);
      allow create, update: if isOwner(athleteId);
      allow delete: if false;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
